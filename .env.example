# ─── Cultura T Educación — Variables de entorno ───────────────────────
# Copiar a .env y completar valores

# Seguridad
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-django-secret-key

# Base de datos (Supabase)
# USER y HOST los obtienes de tu panel de Supabase → Dashboard → Connection String
DATABASE_URL=postgresql://postgres.YOUR_USER:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# Dominios permitidos (producción + desarrollo local)
ALLOWED_HOSTS=educacion-7tge.onrender.com,localhost,127.0.0.1
